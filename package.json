{
  "name": "vstart2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "dev:api": "node --watch server/index.mjs",
    "start:api": "node server/index.mjs",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration": "node scripts/integration-smoke.mjs",
    "migrate:v1": "node scripts/migrate-v1.mjs",
    "import:vstart1:backgrounds": "node scripts/import-vstart1-backgrounds.mjs",
    "backfill:icons": "node scripts/backfill-shortcut-icons.mjs",
    "agent:spike": "node agent-bridge/protocol-spike.mjs",
    "agent:bridge": "node agent-bridge/index.mjs",
    "agent:bridge:manage": "node agent-bridge/launchd.mjs",
    "agent:bridge:smoke": "node agent-bridge/bridge-smoke.mjs",
    "test:agent-bridge": "vitest run agent-bridge",
    "test:watch": "vitest",
    "check:persistence": "node scripts/check-browser-persistence.mjs",
    "verify": "npm run lint && npm run check:persistence && npm test && npm run build"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "vite": "^6.0.5",
    "vitest": "^4.1.10"
  }
}
