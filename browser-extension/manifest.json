{
  "manifest_version": 3,
  "name": "V Start Multi-Tool",
  "description": "Local browser companion for V Start inline tools, beginning with temporary iframe assistance.",
  "version": "0.1.0",
  "minimum_chrome_version": "120",
  "permissions": [
    "alarms",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": [
        "src/content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "V Start Multi-Tool"
  }
}
